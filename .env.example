# Monad Agentic Payment MCP Server Configuration
# Server connection settings
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3000
MCP_SERVER_URL=http://localhost:3000/

# Agent configuration
AGENT_ID=monad-agent-001
AGENT_NAME=Monad Blitz Agent
AGENT_PERMISSIONS=["transfer", "read"]

# Security configuration
# Default daily budget limit in native coin
DEFAULT_DAILY_BUDGET=100
DEFAULT_WEEKLY_BUDGET=500
# Default session key expiration in seconds (24 hours)
DEFAULT_SESSION_EXPIRATION=86400

# Storage paths
WALLET_STORAGE_PATH=./wallets
BUDGET_STORAGE_PATH=./budgets
SESSION_KEY_STORAGE_PATH=./session-keys
AUDIT_STORAGE_PATH=./audit

# Blockchain configuration
# Monad testnet RPC endpoint
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143
# Block explorer for transaction verification
BLOCK_EXPLORER=https://testnet.monadexplorer.com
